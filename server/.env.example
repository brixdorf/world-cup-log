# ── Server ───────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development          # Set to "production" on the server

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/worldcuplog.db # Relative to server/ — adjust for prod

# ── football-data.org ────────────────────────────────────────────────────────
FOOTBALL_DATA_API_KEY=your_api_key_here

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
OWNER_USERNAME=your_username
# Generate with: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',12));"
OWNER_PASSWORD_HASH=$2b$12$...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev: http://localhost:5173
# Prod: https://yourwebsite.com
CORS_ORIGIN=http://localhost:5173
